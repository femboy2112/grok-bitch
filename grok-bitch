# git helpers (best-effort change reporting; never required)
# ---------------------------------------------------------------------------
def git_porcelain(dir_: Path):
    try:
        out = subprocess.run(
            ["git", "-C", str(dir_), "status", "--porcelain"],
            capture_output=True, text=True, timeout=30,
        )
        if out.returncode != 0:
            return None
        return out.stdout
    except (OSError, subprocess.SubprocessError):
        return None


def parse_porcelain(text):
    """Return set of (status, path) for a porcelain v1 listing."""
    s = set()
    if not text:
        return s
    for line in text.splitlines():
        if len(line) < 4:
            continue
        s.add((line[:2], line[3:]))
    return s


def changes_from_git(before_text, after_text):
    before = {p for _, p in parse_porcelain(before_text)}
    after = parse_porcelain(after_text)
    created, modified, deleted = [], [], []
    for st, p in sorted(after):
        if "?" in st:
            created.append(p)
        elif "D" in st:
            deleted.append(p)
        else:
            modified.append(p)
    # Only report paths grok newly touched (not pre-existing dirty state)
    pre = before
    return {
        "created": [p for p in created if p not in pre],
        "modified": [p for p in modified if p not in pre],
        "deleted": deleted,
        "note": "git porcelain delta (grok's net changes vs pre-run state)",
    }


# ---------------------------------------------------------------------------
# Resource limiting — keep grok's process tree from OOM'ing / pegging the box.
# ---------------------------------------------------------------------------
def parse_size(s) -> int:
    """'4G' / '512M' / '2048K' / '1073741824' -> bytes."""
    if isinstance(s, int):
        return s
    s = str(s).strip().upper()
    mult = 1
    if s and s[-1] in "KMGT":
        mult = {"K": 1 << 10, "M": 1 << 20, "G": 1 << 30, "T": 1 << 40}[s[-1]]
        s = s[:-1]
    return int(float(s) * mult)


class Limits:
    def __init__(self, mem_bytes, cpu_n, max_output_bytes, nice=DEFAULT_NICE,
                 enabled=True, interval=WATCHDOG_INTERVAL):
        self.mem_bytes = mem_bytes
        self.cpu_n = max(1, cpu_n)
        self.max_output_bytes = max_output_bytes
        self.nice = nice
        self.enabled = enabled
        self.interval = interval


_SYSTEMD_OK = None


def systemd_available() -> bool:
    """True iff we can place a command in a transient user cgroup scope."""
    global _SYSTEMD_OK
    if os.environ.get("GROK_BITCH_NO_SYSTEMD"):
        return False  # test hook: force the pure-/proc watchdog path
    if _SYSTEMD_OK is not None:
        return _SYSTEMD_OK
    ok = False
    if shutil.which("systemd-run") and os.environ.get("XDG_RUNTIME_DIR"):
        try:
            r = subprocess.run(
                ["systemd-run", "--user", "--scope", "--quiet",
                 "-p", "MemoryMax=64M", "-p", "MemorySwapMax=0", "--", "true"],
                capture_output=True, timeout=15)
            ok = (r.returncode == 0)
        except (OSError, subprocess.SubprocessError):
            ok = False
    _SYSTEMD_OK = ok
    return ok


def systemd_wrap(cmd, limits: Limits, unit: str):
    quota = f"{limits.cpu_n * 100}%"
    high = int(limits.mem_bytes * 0.9)
    return [
        "systemd-run", "--user", "--scope", "--quiet", f"--unit={unit}",
        "-p", f"MemoryMax={limits.mem_bytes}",
        "-p", "MemorySwapMax=0",            # NO swap thrash on this 32G-swap box
        "-p", f"MemoryHigh={high}",
        "-p", f"CPUQuota={quota}",
        "-p", "TasksMax=512",               # cap the fork-bomb / parallel blast
        "--",
    ] + list(cmd)


def _preexec(limits: Limits, ctty_fd=None):
    def fn():
        try:
            os.setsid()
        except OSError:
            pass
        if ctty_fd is not None:
            # Make the pty our controlling terminal so grok's Landlock sandbox
            # can open /dev/tty and actually ENGAGE (it silently no-ops without).
            try:
                fcntl.ioctl(ctty_fd, termios.TIOCSCTTY, 0)
            except OSError:
                pass
        try:
            cores = sorted(os.sched_getaffinity(0))[:limits.cpu_n]
            if cores:
                os.sched_setaffinity(0, set(cores))
        except (OSError, AttributeError):
            pass
        try:
            os.nice(limits.nice)
        except OSError:
            pass
    return fn


def _read_ppid(pid):
    try:
        with open(f"/proc/{pid}/stat") as f:
            data = f.read()
        rparen = data.rfind(")")
        fields = data[rparen + 2:].split()
        return int(fields[1])  # state=fields[0], ppid=fields[1]
    except (OSError, IndexError, ValueError):
        return None


def _rss_bytes(pid):
    try:
        with open(f"/proc/{pid}/statm") as f:
            resident_pages = int(f.read().split()[1])
        return resident_pages * os.sysconf("SC_PAGE_SIZE")
    except (OSError, IndexError, ValueError):
        return 0


def descendants(root_pid):
    """All live descendants of root_pid (inclusive), via /proc ppid links."""
    children = {}
    try:
        entries = os.listdir("/proc")
    except OSError:
        return [root_pid]
    for e in entries:
        if not e.isdigit():
            continue
        pid = int(e)
        ppid = _read_ppid(pid)
        if ppid is not None:
            children.setdefault(ppid, []).append(pid)
    seen, stack = [], [root_pid]
    while stack:
        p = stack.pop()
        seen.append(p)
        stack.extend(children.get(p, []))
    return seen


def tree_rss_bytes(root_pid):
    return sum(_rss_bytes(p) for p in descendants(root_pid))


def kill_tree(root_pid):
    pids = descendants(root_pid)
    for sig in (signal.SIGTERM, signal.SIGKILL):
        for p in pids:
            try:
                os.kill(p, sig)
            except (ProcessLookupError, PermissionError):
                pass
        if sig == signal.SIGTERM:
            time.sleep(0.5)
        # also try the process group
        try:
            os.killpg(os.getpgid(root_pid), sig)
        except (ProcessLookupError, PermissionError):
            pass


def run_limited(cmd, cwd, timeout_s, limits: Limits, stdout_path: Path,
                stderr_path: Path, unit: str, with_pty: bool = False):
    """Run a command under memory/CPU caps with a wall-clock + RSS + output
    watchdog. Returns (state, info). state in
    {ok, timeout, resource, output, spawn_error}.

    with_pty: allocate a controlling pty for the child (required so grok's
    Landlock sandbox engages). stdin is /dev/null regardless."""
    use_systemd = limits.enabled and systemd_available()
    real_cmd = systemd_wrap(cmd, limits, unit) if use_systemd else list(cmd)
    enforced = "systemd-cgroup" if use_systemd else (
        "watchdog" if limits.enabled else "none")

    master = slave = None
    drain_stop = threading.Event()
    if with_pty:
        try:
            master, slave = pty.openpty()
        except OSError:
            master = slave = None  # best effort; sandbox may then not engage

    start = now()
    deadline = start + timeout_s
    peak_rss = 0
    state = "ok"
    with open(stdout_path, "wb") as out_f, open(stderr_path, "wb") as err_f:
        popen_kw = dict(cwd=str(cwd), stdout=out_f, stderr=err_f,
                        stdin=subprocess.DEVNULL,
                        preexec_fn=_preexec(limits, slave))
        if slave is not None:
            popen_kw["pass_fds"] = (slave,)
        try:
            proc = subprocess.Popen(real_cmd, **popen_kw)
        except FileNotFoundError as e:
            if master is not None:
                os.close(master)
            if slave is not None:
                os.close(slave)
            return "spawn_error", {"error": str(e), "enforced_by": enforced}
        if slave is not None:
            os.close(slave)  # parent drops its copy; child holds the ctty
        if master is not None:
            # Keep the master open & drained for the child's lifetime, else
            # closing it would SIGHUP the controlling-tty session and kill grok.
            def _drain(fd):
                while not drain_stop.is_set():
                    try:
                        if not os.read(fd, 4096):
                            break
                    except OSError:
                        break
            threading.Thread(target=_drain, args=(master,), daemon=True).start()
        while True:
            rc = proc.poll()
            if rc is not None:
                break
            t = now()
            if t >= deadline:
                state = "timeout"
                kill_tree(proc.pid)
                break
            if limits.enabled:
                rss = tree_rss_bytes(proc.pid)
                peak_rss = max(peak_rss, rss)
                if rss > limits.mem_bytes:
                    state = "resource"
                    kill_tree(proc.pid)
                    break
            try:
                osz = stdout_path.stat().st_size + stderr_path.stat().st_size
            except OSError:
                osz = 0
            if osz > limits.max_output_bytes:
                state = "output"
                kill_tree(proc.pid)
                break
            time.sleep(limits.interval)
        try:
            rc = proc.wait(timeout=10)
        except subprocess.TimeoutExpired:
            kill_tree(proc.pid)
            rc = proc.wait()
        drain_stop.set()
        if master is not None:
            try:
                os.close(master)
            except OSError:
                pass
    # Post-exit output check: a fast burst can finish before the watchdog samples,
    # but it still produced too much output -> still a resource breach.
    if state == "ok":
        try:
            osz = stdout_path.stat().st_size + stderr_path.stat().st_size
        except OSError:
            osz = 0
        if osz > limits.max_output_bytes:
            state = "output"
    dur = now() - start
    info = {
        "exit": rc,
        "duration_s": round(dur, 3),
        "peak_rss_mb": round(peak_rss / (1 << 20), 1),
        "mem_max_mb": round(limits.mem_bytes / (1 << 20), 1),
        "cpu_cores": limits.cpu_n,
        "enforced_by": enforced,
    }
    # If the cgroup OOM-killed inside the scope, classify it as resource even
    # though our sampler may have missed the sub-interval spike.
    if state == "ok" and rc not in (0,) and peak_rss >= 0.9 * limits.mem_bytes \
            and limits.enabled:
        state = "resource"
    return state, info


# ---------------------------------------------------------------------------
# Building & running the grok command
# ---------------------------------------------------------------------------
def resolve_guards(dir_: Path, explicit, auto_guard: bool):
    roots = []
    src = {}
    if auto_guard:
        for rel in AUTO_GUARD_RELPATHS:
            cand = dir_ / rel
            if cand.exists():
                roots.append(cand)
                src[str(cand.resolve())] = "auto"
    # workspace config file: .grok-bitch.guards (newline-separated relpaths)
    cfg = dir_ / ".grok-bitch.guards"
    if cfg.exists():
        for line in cfg.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            cand = (dir_ / line)
            roots.append(cand)
            src[str(cand.resolve())] = "config"
    for g in explicit or []:
        cand = Path(g)
        if not cand.is_absolute():
            cand = dir_ / g
        roots.append(cand)
        src[str(cand.resolve())] = "flag"
    return roots, src


