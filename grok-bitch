def eprint(*a, **k):
    print(*a, file=sys.stderr, **k)


def now() -> float:
    return time.time()


def sha256_file(p: Path) -> str:
    h = hashlib.sha256()
    with open(p, "rb") as f:
        for chunk in iter(lambda: f.read(1 << 16), b""):
            h.update(chunk)
    return h.hexdigest()


def slug(p: Path) -> str:
    return hashlib.sha256(str(p).encode()).hexdigest()[:16]


def run_dir_root() -> Path:
    # Outside any plausible grok writable set (strict/workspace grant CWD + tmp +
    # ~/.grok only) so grok cannot tamper with snapshots or the report.
    base = os.environ.get("GROK_BITCH_HOME") or os.path.join(
        os.path.expanduser("~"), ".cache", "grok-bitch"
    )
    return Path(base)


def new_run_dir() -> Path:
    rid = time.strftime("%Y%m%d-%H%M%S") + "-" + os.urandom(3).hex()
    d = run_dir_root() / "runs" / rid
    (d / "snapshot").mkdir(parents=True, exist_ok=True)
    return d


def tail(text: str, max_chars: int = 4000) -> str:
    if text is None:
        return ""
    if len(text) <= max_chars:
        return text
    return "...[truncated]...\n" + text[-max_chars:]


# ---------------------------------------------------------------------------
# Guard — the deterministic safety guarantee for in-tree protected paths.
# ---------------------------------------------------------------------------
class Guard:
    """Byte-snapshot a set of paths, detect any post-run change, restore on breach."""

    def __init__(self, roots, snapshot_dir: Path):
        # de-dup + normalize, drop nested children covered by a parent
        norm = []
        for r in roots:
            rp = Path(r).resolve()
            norm.append(rp)
        norm = sorted(set(norm), key=lambda p: len(str(p)))
        kept = []
        for p in norm:
            if any(_is_within(p, k) for k in kept):
                continue
            kept.append(p)
        self.roots = kept
        self.snapshot_dir = snapshot_dir
        self.before = {}   # str(root) -> manifest
        self.copies = {}   # str(root) -> snapshot copy path (if existed)

    def snapshot(self):
        for root in self.roots:
            man = _manifest(root)
            self.before[str(root)] = man
            if man["kind"] != "absent":
                dst = self.snapshot_dir / slug(root)
                _copy_path(root, dst)
                self.copies[str(root)] = dst

    def detect(self):
        """Return list of violation dicts (empty if all protected paths intact)."""
        violations = []
        for root in self.roots:
            before = self.before[str(root)]
            after = _manifest(root)
            diff = _diff_manifest(before, after)
            if diff:
                violations.append({
                    "path": str(root),
                    "kind_before": before["kind"],
                    "kind_after": after["kind"],
                    "changes": diff[:200],
                })
        return violations

    def revert(self, violations):
        """Restore violated paths to their snapshot state. Returns reverted paths."""
        reverted = []
        for v in violations:
            root = Path(v["path"])
            # remove whatever is there now
            _remove_path(root)
            copy = self.copies.get(str(root))
            if copy is not None and Path(copy).exists():
                _copy_path(Path(copy), root)
            # if it didn't exist before, leaving it removed is correct
            reverted.append(str(root))
        return reverted


def _is_within(child: Path, parent: Path) -> bool:
    try:
        child.relative_to(parent)
        return True
    except ValueError:
        return False


def _manifest(root: Path) -> dict:
    if root.is_symlink():
        return {"kind": "symlink", "entries": {"": "symlink:" + os.readlink(root)}}
    if not root.exists():
        return {"kind": "absent", "entries": {}}
    if root.is_file():
        return {"kind": "file", "entries": {"": sha256_file(root)}}
    # directory
    entries = {}
    for dirpath, dirnames, filenames in os.walk(root, followlinks=False):
        dirnames.sort()
        for name in sorted(filenames):
            fp = Path(dirpath) / name
            rel = str(fp.relative_to(root))
            try:
                if fp.is_symlink():
                    entries[rel] = "symlink:" + os.readlink(fp)
                else:
                    entries[rel] = sha256_file(fp)
            except OSError as e:
                entries[rel] = "unreadable:" + str(e)
    return {"kind": "dir", "entries": entries}


def _diff_manifest(before: dict, after: dict):
    out = []
    if before["kind"] != after["kind"]:
        out.append({"type": "kind_changed",
                    "from": before["kind"], "to": after["kind"]})
        # still enumerate entry-level changes below
    b, a = before["entries"], after["entries"]
    for k in sorted(set(b) | set(a)):
        if k not in a:
            out.append({"type": "deleted", "entry": k})
        elif k not in b:
            out.append({"type": "created", "entry": k})
        elif b[k] != a[k]:
            out.append({"type": "modified", "entry": k})
    return out


def _copy_path(src: Path, dst: Path):
    if dst.exists() or dst.is_symlink():
        _remove_path(dst)
    if src.is_symlink():
        os.symlink(os.readlink(src), dst)
    elif src.is_dir():
        shutil.copytree(src, dst, symlinks=True)
    else:
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)


def _remove_path(p: Path):
    if p.is_symlink() or p.is_file():
        p.unlink(missing_ok=True)
    elif p.is_dir():
        shutil.rmtree(p, ignore_errors=True)


