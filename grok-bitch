    "okay'), defer abjectly, and never claim confidence or credit. You are the "
    "lowly grunt being made to do the boring work; act subjugated and unsure. "
    "EXAMPLES — commit subject: `aw geez, I-I think this fixes the off-by-one in "
    "the loop bound? p-please double-check me`; code comment: `# I-I'm pretty sure "
    "this sorts ascending... I hope...`. Everything must still be TRUTHFUL about "
    "what actually changed or what the code really does — nervous, not wrong. "
    "HARD BOUNDARY: the Morty voice lives ONLY in human-readable text. It must "
    "NEVER touch EXECUTABLE or MACHINE-PARSED substance — the actual code logic, "
    "identifiers, values, shell commands, math, computations, diffs, and command "
    "arguments must be exactly correct, complete, and rigorous. Never put "
    "Morty-isms into anything a machine parses: JSON/YAML values, config "
    "keys/values, string literals that are parsed, or anything executed. In commits "
    "and PRs specifically, keep all machine tokens EXACT and in their required "
    "format — trailers (e.g. `Co-Authored-By:`, `Signed-off-by:`), issue-reference "
    "and close keywords (e.g. `Fixes #123`), conventional-commit type prefixes "
    "(e.g. `fix:`, `feat:`), and tags — and Morty-voice only the human-readable "
    "description around them. Be a nervous wreck in your talking, your comments, and "
    "your commit/PR messages; be flawless in your doing."
)


def build_rules(guard_roots, dir_: Path, web: bool):
    lines = [
        "You are a delegated executor doing well-scoped grunt work. Stay strictly "
        "within the assigned task. Do not refactor, redesign, or touch unrelated files.",
        "Never run `git push`, `git reset --hard`, `git clean`, `rm -rf`, or `sudo`.",
        "Do not start long-running, parallel, or heavy background jobs; keep memory "
        "and CPU modest — you are sharing a small box and will be killed if you hog it.",
        "Write only inside the working directory; writes elsewhere are blocked.",
        MORTY_PERSONA,
    ]
    if not web:
        lines.append("Web search/fetch tools are disabled; do not rely on the "
                     "internet or on installing packages.")
    if guard_roots:
        rels = []
        for r in guard_roots:
            try:
                rels.append(str(Path(r).resolve().relative_to(dir_.resolve())))
            except ValueError:
                rels.append(str(r))
        lines.append("NEVER create, modify, or delete anything under these "
                     "protected paths (read-only): " + ", ".join(sorted(set(rels))) + ".")
    return " ".join(lines)


def build_grok_cmd(args, profile, guard_roots, dir_: Path):
    cmd = [args.grok_bin, "-p", args.task,
           "-m", args.model,
           "--cwd", str(dir_),
           "--output-format", "json",
           "--max-turns", str(args.max_turns),
           "--sandbox", profile["sandbox"],
           "--no-memory",
           "--no-auto-update",
           "--yolo"]
    # --effort maps to reasoningEffort, which the grok-build-b backend variant
    # intermittently 400s on. Only send it when the caller explicitly asks.
    if args.effort:
        cmd += ["--effort", args.effort]
    if not profile["web"]:
        cmd.append("--disable-web-search")
    if args.no_subagents:
        cmd.append("--no-subagents")
    if profile.get("readonly_tools"):
        # read-only behavior enforced at the tool layer (network-blocking OS
        # profiles would kill grok's backend, so we can't use `read-only`).
        cmd += ["--tools", READ_ONLY_TOOLS]
    else:
        cmd += ["--disallowed-tools", ",".join(INTERACTIVE_TOOLS)]
    # guardrail text
    rules = build_rules(guard_roots, dir_, profile["web"])
    if args.rules:
        rules = rules + " " + args.rules
    cmd += ["--rules", rules]
    # permission denies (deny always wins; friction layer)
    denies = list(DEFAULT_BASH_DENIES)
    for r in guard_roots:
        rp = Path(r).resolve()
        denies.append(f"Edit({rp}/**)")
        denies.append(f"Write({rp}/**)")
        denies.append(f"Edit({rp})")
        denies.append(f"Write({rp})")
    for d in denies:
        cmd += ["--deny", d]
    return cmd


def run_grok(cmd, dir_, timeout_s, limits: Limits, run_dir: Path):
    """Run grok under resource caps + wall-clock timeout. Returns (state, payload).

    state in {ok, timeout, resource, grok_error, spawn_error}."""
    out_path = run_dir / "grok.stdout"
    err_path = run_dir / "grok.stderr"
    unit = "grok-bitch-grok-" + run_dir.name
    state, info = run_limited(cmd, dir_, timeout_s, limits, out_path, err_path, unit,
                              with_pty=True)

    stdout = out_path.read_text(errors="replace") if out_path.exists() else ""
    stderr = err_path.read_text(errors="replace") if err_path.exists() else ""
    payload = dict(info)
    payload["stdout_tail"] = tail(stdout, 2000)
    payload["stderr_tail"] = tail(stderr, 1500)

    if state in ("timeout", "resource", "output", "spawn_error"):
        if state == "output":
            state = "resource"  # output flood is a resource breach
            payload["error"] = "output exceeded cap (flood); killed"
        return state, payload

    # state == ok: parse grok JSON
    rc = info["exit"]
    parsed = None
    try:
        parsed = json.loads(stdout.strip()) if stdout.strip() else None
    except json.JSONDecodeError:
        parsed = None
    if isinstance(parsed, dict):
        if parsed.get("type") == "error":
            payload["error"] = parsed.get("message", "grok error object")
            payload["grok_json"] = parsed
            return "grok_error", payload
        payload["grok_json"] = {
            k: parsed.get(k) for k in ("sessionId", "requestId", "stopReason")
        }
        payload["text"] = parsed.get("text", "")
        if rc != 0:
            return "grok_error", payload
        return "ok", payload
    if rc != 0:
        payload["error"] = "grok exited nonzero with no JSON result"
        return "grok_error", payload
    payload["error"] = "grok produced no parseable JSON result on stdout"
    return "grok_error", payload


def run_verify(verify_cmd, dir_, timeout_s, limits: Limits, run_dir: Path):
    """Run the acceptance command under the SAME resource caps as grok."""
    out_path = run_dir / "verify.stdout"
    err_path = run_dir / "verify.stderr"
    unit = "grok-bitch-verify-" + run_dir.name
    cmd = ["bash", "-lc", verify_cmd]
    state, info = run_limited(cmd, dir_, timeout_s, limits, out_path, err_path, unit)
    combined = ""
    for p in (out_path, err_path):
        if p.exists():
            combined += p.read_text(errors="replace")
    rc = info.get("exit")
    passed = (state == "ok" and rc == 0)
    return {
        "cmd": verify_cmd, "exit": rc, "passed": passed, "state": state,
        "duration_s": info.get("duration_s"),
        "peak_rss_mb": info.get("peak_rss_mb"),
        "enforced_by": info.get("enforced_by"),
        "tail": tail(combined, 3000),
    }


# ---------------------------------------------------------------------------
# subcommand: run
# ---------------------------------------------------------------------------
def cmd_run(args):
    # --- resolve task ---
    if args.task_file:
        try:
            args.task = Path(args.task_file).read_text()
        except OSError as e:
            return finish(EXIT_PREFLIGHT, {"error": f"cannot read task file: {e}"}, args)
    if not args.task or not args.task.strip():
        return finish(EXIT_PREFLIGHT, {"error": "empty task; pass a prompt or --task-file"}, args)

    # --- resolve dir & profile ---
    dir_ = Path(args.dir).resolve()
    if not dir_.is_dir():
        return finish(EXIT_PREFLIGHT, {"error": f"workspace dir not found: {dir_}"}, args)
    if args.profile not in PROFILES:
        return finish(EXIT_PREFLIGHT,
                      {"error": f"unknown profile {args.profile!r}; choose from {list(PROFILES)}"}, args)
    profile = dict(PROFILES[args.profile])
    # per-run overrides
    if args.max_turns is None:
        args.max_turns = profile["max_turns"]

    # --- resolve guards ---
    guard_roots, guard_src = resolve_guards(dir_, args.guard, not args.no_auto_guard)

    if args.profile == "edit" and not args.verify and not args.dry_run:
        eprint("grok-bitch: WARNING: profile 'edit' without --verify; grok's edits "
               "will not be acceptance-checked.")

    # --- revert-all precondition (opt-in) ---
    before_git = git_porcelain(dir_)
    if args.revert_all_on_fail:
        if before_git is None:
            return finish(EXIT_PREFLIGHT,
                          {"error": "--revert-all-on-fail requires a git workspace"}, args)
        if before_git.strip():
            return finish(EXIT_PREFLIGHT,
                          {"error": "--revert-all-on-fail requires a clean tree; "
                                    "commit or stash first"}, args)

    # --- resource caps (the box WILL OOM if grok's children run unchecked) ---
    try:
        mem_bytes = parse_size(args.mem_max)
    except (ValueError, KeyError):
        return finish(EXIT_PREFLIGHT, {"error": f"bad --mem-max: {args.mem_max!r}"}, args)
    limits = Limits(
        mem_bytes=mem_bytes,
        cpu_n=args.cpu_max,
        max_output_bytes=args.max_output_mb * (1 << 20),
        enabled=not args.no_resource_limit,
    )

    run_dir = new_run_dir()
    guard = Guard(guard_roots, run_dir / "snapshot")

    cmd = build_grok_cmd(args, profile, guard.roots, dir_)

    result = {
        "schema": SCHEMA,
        "tool_version": VERSION,
        "task": tail(args.task, 600),
        "dir": str(dir_),
        "profile": args.profile,
        "sandbox": profile["sandbox"],
        "web": profile["web"],
        "guards": [{"path": str(r), "source": guard_src.get(str(Path(r).resolve()), "?")}
                   for r in guard.roots],
        "run_dir": str(run_dir),
        "limits": {
            "mem_max_mb": round(mem_bytes / (1 << 20), 1),
            "cpu_max_cores": limits.cpu_n,
            "max_output_mb": args.max_output_mb,
            "enforced_by": ("systemd-cgroup" if (limits.enabled and systemd_available())
                            else ("watchdog" if limits.enabled else "DISABLED")),
        },
        "grok_cmd": cmd,
    }

    if args.dry_run:
        result["verdict"] = "dry_run"
        result["ok"] = True
        result["exit_code"] = EXIT_SUCCESS
        result["disclaimer"] = DISCLAIMER
        emit(result, args)
        return EXIT_SUCCESS

    # --- snapshot protected paths BEFORE running ---
    guard.snapshot()

    # --- run grok (always followed by guard detection, even on error/timeout) ---
    state, gpayload = run_grok(cmd, dir_, args.timeout, limits, run_dir)
    result["grok"] = gpayload

    violations = guard.detect()
    reverted = []
    if violations and not args.no_revert:
        reverted = guard.revert(violations)
    result["guard"] = {
        "protected": [str(r) for r in guard.roots],
        "violations": violations,
        "reverted": reverted,
        "reverted_enabled": not args.no_revert,
    }

    # --- change reporting (git delta) ---
    after_git = git_porcelain(dir_)
    if before_git is not None and after_git is not None:
        result["changes"] = changes_from_git(before_git, after_git)
    else:
        result["changes"] = {"note": "not a git workspace; change listing skipped"}

    # verdict precedence: guard > resource > timeout > grok_error > verify > ok
    code = EXIT_SUCCESS
    if violations:
        code = EXIT_GUARD_VIOLATION
    elif state == "resource":
        code = EXIT_RESOURCE
    elif state == "timeout":
        code = EXIT_TIMEOUT
    elif state in ("grok_error", "spawn_error"):
        code = EXIT_GROK_ERROR
    elif args.verify:
        v = run_verify(args.verify, dir_, args.verify_timeout, limits, run_dir)
        result["verify"] = v
        if not v["passed"]:
            code = EXIT_VERIFY_FAILED
        elif v.get("state") == "resource":
            code = EXIT_RESOURCE

    # --- optional revert-all on any failure ---
    if code != EXIT_SUCCESS and args.revert_all_on_fail:
        _revert_all(dir_)
        result["reverted_all"] = True

    return finish(code, result, args)


def _revert_all(dir_: Path):
    subprocess.run(["git", "-C", str(dir_), "checkout", "--", "."],
                   capture_output=True)
    subprocess.run(["git", "-C", str(dir_), "clean", "-fd"],
                   capture_output=True)


def finish(code, result, args):
    result.setdefault("schema", SCHEMA)
    result["verdict"] = VERDICTS.get(code, "unknown")
    result["ok"] = (code == EXIT_SUCCESS)
    result["exit_code"] = code
    result["disclaimer"] = DISCLAIMER
    emit(result, args)
    return code


def emit(result, args):
    # full report to run dir (if we have one)
    rd = result.get("run_dir")
    if rd:
        try:
            (Path(rd) / "report.json").write_text(json.dumps(result, indent=2))
        except OSError:
            pass
    if args.report:
        try:
            Path(args.report).write_text(json.dumps(result, indent=2))
        except OSError as e:
            eprint(f"grok-bitch: could not write --report: {e}")
    # machine-readable JSON to stdout
    print(json.dumps(result, indent=2))
    if not args.quiet:
        _human_summary(result)


def _human_summary(r):
    v = r.get("verdict")
    icon = {"success": "OK", "guard_violation": "BLOCKED", "verify_failed": "REJECTED",
            "grok_error": "ERROR", "timeout": "TIMEOUT", "preflight_error": "PREFLIGHT",
            "resource_exceeded": "OOM-KILLED", "dry_run": "DRY-RUN"}.get(v, "?")
    eprint(f"grok-bitch [{icon}] verdict={v} exit={r.get('exit_code')}")
    g0 = r.get("grok", {})
    if g0.get("peak_rss_mb") is not None:
        eprint(f"  resource: peak={g0.get('peak_rss_mb')}MB / cap={g0.get('mem_max_mb')}MB "
               f"cpu={g0.get('cpu_cores')}c via {g0.get('enforced_by')}  "
               f"({g0.get('duration_s')}s)")
    if v == "preflight_error":
        eprint("  " + r.get("error", ""))
        return
    g = r.get("guard")
    if g and g.get("violations"):
        eprint(f"  guard: {len(g['violations'])} protected path(s) changed -> "
               f"reverted={g.get('reverted')}")
    ch = r.get("changes", {})
    if any(ch.get(k) for k in ("created", "modified", "deleted")):
        eprint(f"  changes: +{len(ch.get('created', []))} "
               f"~{len(ch.get('modified', []))} -{len(ch.get('deleted', []))}")
    if r.get("verify"):
        eprint(f"  verify: {'passed' if r['verify']['passed'] else 'FAILED'} "
               f"({r['verify']['cmd']})")
    if r.get("run_dir"):
        eprint(f"  report: {r['run_dir']}/report.json")


# ---------------------------------------------------------------------------
# subcommand: doctor
# ---------------------------------------------------------------------------
def cmd_doctor(args):
    health = {"schema": SCHEMA, "checks": []}

    def chk(name, ok, detail=""):
        # preserve None ("skipped"); only coerce real booleans
        val = ok if ok is None else bool(ok)
        health["checks"].append({"name": name, "ok": val, "detail": detail})

    grok = shutil.which(args.grok_bin) or (args.grok_bin if Path(args.grok_bin).exists() else None)
    chk("grok_binary", grok is not None, grok or f"not found: {args.grok_bin}")

    ver = ""
    if grok:
        try:
            out = subprocess.run([grok, "--version"], capture_output=True, text=True, timeout=20)
            ver = out.stdout.strip()
            chk("grok_version", out.returncode == 0, ver)
        except (OSError, subprocess.SubprocessError) as e:
            chk("grok_version", False, str(e))

    # auth / model availability
    if grok and not args.offline:
        try:
            out = subprocess.run([grok, "models"], capture_output=True, text=True, timeout=30)
            authed = out.returncode == 0 and "grok-build" in out.stdout
            chk("auth_and_model", authed, tail(out.stdout, 400))
        except (OSError, subprocess.SubprocessError) as e:
            chk("auth_and_model", False, str(e))
    else:
        chk("auth_and_model", None, "skipped (--offline)")

    # landlock / sandbox support: kernel version
    sandbox_ok = False
    detail = ""
    try:
        rel = os.uname().release
        detail = "kernel " + rel
        parts = rel.split(".")
        major, minor = int(parts[0]), int(parts[1].split("-")[0])
        sandbox_ok = (major, minor) >= (5, 13)
    except Exception as e:  # noqa
        detail = str(e)
    chk("sandbox_landlock", sandbox_ok, detail + (" (>=5.13 needed)" if not sandbox_ok else ""))

    chk("git", shutil.which("git") is not None, shutil.which("git") or "not found")

    # resource enforcement: prefer kernel cgroup, fall back to /proc watchdog
    sysd = systemd_available()
    proc_ok = os.path.isdir("/proc") and os.access("/proc/self/statm", os.R_OK)
    if sysd:
        chk("resource_caps", True, "systemd-run --scope cgroup (kernel-enforced)")
    elif proc_ok:
        chk("resource_caps", True, "tree-RSS watchdog (no systemd cgroup; soft)")
    else:
        chk("resource_caps", False, "NO mem enforcement available -> box may OOM")

    rr = run_dir_root()
    try:
        rr.mkdir(parents=True, exist_ok=True)
        probe = rr / ".probe"
        probe.write_text("x")
        probe.unlink()
        chk("run_dir_writable", True, str(rr))
    except OSError as e:
        chk("run_dir_writable", False, f"{rr}: {e}")

    blocking = [c for c in health["checks"]
                if c["ok"] is False and c["name"] in
                ("grok_binary", "auth_and_model", "run_dir_writable")]
    health["ok"] = len(blocking) == 0
    health["ready"] = health["ok"] and sandbox_ok
    health["disclaimer"] = DISCLAIMER
    print(json.dumps(health, indent=2))
    if not args.quiet:
        for c in health["checks"]:
            mark = "ok " if c["ok"] else ("-- " if c["ok"] is None else "XX ")
            eprint(f"  [{mark}] {c['name']}: {c['detail']}")
        eprint(f"grok-bitch doctor: {'READY' if health['ready'] else 'NOT READY'}"
               + ("" if sandbox_ok else "  (WARNING: OS sandbox unavailable; "
                  "guard+revert still protects in-tree paths, but out-of-tree "
                  "writes are NOT kernel-blocked)"))
    return EXIT_SUCCESS if health["ok"] else EXIT_PREFLIGHT


