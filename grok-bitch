def cmd_profiles(args):
    out = {"schema": SCHEMA, "default": DEFAULT_PROFILE, "profiles": PROFILES,
           "disclaimer": DISCLAIMER}
    print(json.dumps(out, indent=2))
    if not args.quiet:
        for name, p in PROFILES.items():
            star = " (default)" if name == DEFAULT_PROFILE else ""
