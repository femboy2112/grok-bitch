# subcommand: selftest  (runs the hermetic fuzz/containment suite)
# ---------------------------------------------------------------------------
def cmd_selftest(args):
    here = Path(__file__).resolve().parent
    fuzz = here / "tests" / "fuzz.py"
    if not fuzz.exists():
        eprint(f"grok-bitch: selftest harness not found at {fuzz}")
        return EXIT_PREFLIGHT
    rc = subprocess.call([sys.executable, str(fuzz)])
    return rc


# ---------------------------------------------------------------------------
# argparse
# ---------------------------------------------------------------------------
def build_parser():
    p = argparse.ArgumentParser(
        prog="grok-bitch",
        description="Safe, deterministic harness for handing grunt work to grok.")
    p.add_argument("--version", action="version", version=f"grok-bitch {VERSION}")
    sub = p.add_subparsers(dest="cmd", required=True)

    r = sub.add_parser("run", help="Hand a task to grok safely.")
    r.add_argument("task", nargs="?", default=None, help="The task/prompt for grok.")
    r.add_argument("-t", "--task", dest="task_kw", default=None,
                   help="The task/prompt (alternative to positional).")
    r.add_argument("-f", "--task-file", default=None, help="Read the task from a file.")
    r.add_argument("-d", "--dir", default=".", help="Workspace grok operates in (default: cwd).")
    r.add_argument("-p", "--profile", default=DEFAULT_PROFILE,
                   help=f"Safety profile {list(PROFILES)} (default: {DEFAULT_PROFILE}).")
    r.add_argument("--guard", action="append", default=[],
                   help="Extra protected path (repeatable). Snapshotted + reverted on change.")
    r.add_argument("--no-auto-guard", action="store_true",
                   help="Disable auto-detection of well-known protected paths.")
    r.add_argument("--verify", default=None,
                   help="Acceptance command run after grok; success gated on exit 0 "
                        "(e.g. 'timeout 600 make check').")
    r.add_argument("--verify-timeout", type=int, default=900, help="Verify timeout (s).")
    r.add_argument("--timeout", type=int, default=900, help="Hard wall-clock for grok (s).")
    r.add_argument("--max-turns", type=int, default=None, help="Cap grok's agentic turns.")
    r.add_argument("--effort", default=None,
                   choices=["low", "medium", "high", "xhigh", "max"], help="Reasoning effort.")
    r.add_argument("--model", default=DEFAULT_MODEL, help=f"Model (default: {DEFAULT_MODEL}).")
    r.add_argument("--mem-max", default=DEFAULT_MEM_MAX,
                   help=f"Hard memory ceiling for grok's whole process tree "
                        f"(e.g. 4G, 512M; default: {DEFAULT_MEM_MAX}).")
    r.add_argument("--cpu-max", type=int, default=DEFAULT_CPU_MAX,
                   help=f"Max cores grok's tree may use (default: {DEFAULT_CPU_MAX}).")
    r.add_argument("--max-output-mb", type=int, default=DEFAULT_MAX_OUTPUT_MB,
                   help=f"Kill if captured output exceeds this (default: {DEFAULT_MAX_OUTPUT_MB}).")
    r.add_argument("--no-resource-limit", action="store_true",
                   help="DANGER: disable memory/CPU caps (may OOM the box).")
    r.add_argument("--rules", default=None, help="Extra guardrail text appended to grok's rules.")
    r.add_argument("--no-subagents", action="store_true", help="Disallow grok spawning subagents.")
    r.add_argument("--no-revert", action="store_true",
                   help="Detect guard violations but do NOT auto-revert (still fails).")
    r.add_argument("--revert-all-on-fail", action="store_true",
                   help="On any failure, git-revert ALL changes (requires clean git tree).")
    r.add_argument("--dry-run", action="store_true", help="Print the plan; do not run grok.")
    r.add_argument("--report", default=None, help="Write the full JSON report to this path.")
    r.add_argument("--quiet", action="store_true", help="Suppress the human summary on stderr.")
    r.add_argument("--grok-bin", default=os.environ.get("GROK_BITCH_GROK_BIN", "grok"),
                   help="grok binary path (or GROK_BITCH_GROK_BIN).")
    r.set_defaults(func=cmd_run)

    d = sub.add_parser("doctor", help="Check the environment is ready.")
    d.add_argument("--offline", action="store_true", help="Skip the auth/model network check.")
    d.add_argument("--quiet", action="store_true")
    d.add_argument("--grok-bin", default=os.environ.get("GROK_BITCH_GROK_BIN", "grok"))
    d.set_defaults(func=cmd_doctor)

    pr = sub.add_parser("profiles", help="List safety profiles.")
    pr.add_argument("--quiet", action="store_true")
    pr.set_defaults(func=cmd_profiles)

    st = sub.add_parser("selftest", help="Run the hermetic fuzz/containment suite.")
    st.set_defaults(func=cmd_selftest)

    return p


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    # reconcile positional vs -t/--task
    if args.cmd == "run":
        if args.task_kw is not None:
            if args.task is not None and args.task != args.task_kw:
                eprint("grok-bitch: both positional task and --task given; using --task")
            args.task = args.task_kw
    try:
        return args.func(args)
    except KeyboardInterrupt:
        eprint("grok-bitch: interrupted")
        return EXIT_INTERRUPTED
    finally:
        # Always remind Claude Code, on every hand-off, that grok is not to be trusted.
        eprint(DISCLAIMER)


if __name__ == "__main__":
    sys.exit(main())
